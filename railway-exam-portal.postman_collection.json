{
  "info": {
    "name": "Railway Exam Portal API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://railwayprep-repo.onrender.com/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "testId", "value": "" },
    { "key": "questionId", "value": "" },
    { "key": "attemptId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "https://railwayprep-repo.onrender.com/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@1234\",\n  \"category\": \"General\",\n  \"targetExam\": \"RRB NTPC\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": []
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"targetExam\": \"RRB Group D\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "List Questions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/questions?subject=Mathematics&difficulty=Easy&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["questions"],
              "query": [
                { "key": "subject", "value": "Mathematics" },
                { "key": "difficulty", "value": "Easy" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get PYQ Topics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/questions/pyq-topics"
          }
        },
        {
          "name": "Get Question by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/questions/{{questionId}}",
            "header": []
          }
        },
        {
          "name": "Create Question (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('questionId', res.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/questions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Mathematics\",\n  \"topic\": \"Number System\",\n  \"difficulty\": \"Easy\",\n  \"year\": 2022,\n  \"exam\": \"RRB NTPC\",\n  \"questionText\": \"What is the LCM of 12 and 18?\",\n  \"options\": [\n    { \"key\": \"A\", \"text\": \"36\" },\n    { \"key\": \"B\", \"text\": \"24\" },\n    { \"key\": \"C\", \"text\": \"72\" },\n    { \"key\": \"D\", \"text\": \"6\" }\n  ],\n  \"correctOption\": \"A\",\n  \"explanation\": \"LCM of 12 and 18 is 36 because 36 is the smallest number divisible by both.\",\n  \"isPYQ\": true,\n  \"tags\": [\"lcm\", \"number system\"]\n}"
            }
          }
        },
        {
          "name": "Update Question (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/questions/{{questionId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"difficulty\": \"Medium\",\n  \"topic\": \"LCM and HCF\"\n}"
            }
          }
        },
        {
          "name": "Delete Question (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/questions/{{questionId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Tests",
      "item": [
        {
          "name": "List Tests",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tests?exam=RRB NTPC&difficulty=Medium&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["tests"],
              "query": [
                { "key": "exam", "value": "RRB NTPC" },
                { "key": "difficulty", "value": "Medium" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Test by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tests/{{testId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Test for Review",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tests/{{testId}}/review",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Create Test (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('testId', res.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tests",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"RRB NTPC Mock Test 1\",\n  \"exam\": \"RRB NTPC\",\n  \"description\": \"Full-length mock test covering all sections\",\n  \"totalQuestions\": 100,\n  \"duration\": 90,\n  \"totalMarks\": 100,\n  \"difficulty\": \"Medium\",\n  \"isPremium\": false,\n  \"sections\": [\n    { \"subject\": \"Mathematics\", \"questionCount\": 30, \"marksPerQuestion\": 1, \"negativeMarks\": 0.33 },\n    { \"subject\": \"Reasoning\", \"questionCount\": 30, \"marksPerQuestion\": 1, \"negativeMarks\": 0.33 },\n    { \"subject\": \"General Knowledge\", \"questionCount\": 40, \"marksPerQuestion\": 1, \"negativeMarks\": 0.33 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Update Test (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tests/{{testId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"RRB NTPC Mock Test 1 - Updated\",\n  \"isPremium\": true\n}"
            }
          }
        },
        {
          "name": "Add Questions to Test (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tests/{{testId}}/questions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questionIds\": [\"{{questionId}}\"]\n}"
            }
          }
        },
        {
          "name": "Delete Test (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/tests/{{testId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Attempts",
      "item": [
        {
          "name": "Submit Attempt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('attemptId', res.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/attempts/{{testId}}/submit",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timeTaken\": 3600,\n  \"answers\": [\n    {\n      \"questionId\": \"{{questionId}}\",\n      \"selectedOption\": \"A\",\n      \"timeTaken\": 30,\n      \"isFlagged\": false\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get My Attempts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/attempts",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Attempt by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/attempts/{{attemptId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get My Analytics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/leaderboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/notifications"
          }
        },
        {
          "name": "Get Notification by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/notifications/{{notificationId}}"
          }
        },
        {
          "name": "Create Notification (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('notificationId', res.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/notifications",
            "header": [
