          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/planner",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Revise Number System\",\n  \"subject\": \"Mathematics\",\n  \"topic\": \"Number System\",\n  \"priority\": \"High\",\n  \"targetDate\": \"2026-03-15\",\n  \"estimatedMinutes\": 60,\n  \"notes\": \"Focus on LCM and HCF problems\"\n}"
            }
