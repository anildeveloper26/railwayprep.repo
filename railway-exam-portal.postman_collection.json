          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/users/{{userId}}/deactivate",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    }
  ]
}
